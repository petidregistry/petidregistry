<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Petid Registry</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=Tektur:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        /* CSS Variables based on Brand Colors */
        :root {
            --brand-dark: #111a7a;
            --brand-light: #2c3683;
            --bg-color: #060913;
            --text-main: #e0e5ff;
            --neon-glow: rgba(44, 54, 131, 0.6);
        }

        /* Global Styles */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(17, 26, 122, 0.15), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(44, 54, 131, 0.15), transparent 25%);
            font-family: 'IBM Plex Sans', sans-serif;
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
        }

        .container {
            width: 100%;
            max-width: 600px;
            padding: 40px;
            box-sizing: border-box;
            position: relative;
            z-index: 1;
        }

        /* Futuristic Form Container */
        .glass-panel {
            background: rgba(17, 26, 122, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(44, 54, 131, 0.3);
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 0 30px rgba(17, 26, 122, 0.2), inset 0 0 20px rgba(44, 54, 131, 0.1);
            position: relative;
            overflow: hidden;
        }

        /* Techy border accents */
        .glass-panel::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--brand-light), transparent);
        }

        /* Typography */
        h1 {
            font-family: 'Tektur', sans-serif;
            font-size: 56px;
            font-weight: 700;
            text-align: center;
            margin: 0 0 30px 0;
            background: linear-gradient(to right, #ffffff, var(--brand-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-transform: uppercase;
            letter-spacing: 1px;
            line-height: 1.1;
            text-shadow: 0 0 20px var(--neon-glow);
        }

        /* Form Layout */
        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .form-group {
            flex: 1;
            display: flex;
            flex-direction: column;
            margin-bottom: 20px;
        }

        label {
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            color: #aeb8eb;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        input {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--brand-light);
            border-radius: 8px;
            padding: 14px 16px;
            color: #ffffff;
            font-family: 'IBM Plex Sans', sans-serif;
            font-size: 16px;
            outline: none;
            transition: all 0.3s ease;
            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.5);
        }

        input:focus {
            border-color: #5563c1;
            box-shadow: 0 0 15px var(--neon-glow), inset 0 0 10px rgba(0, 0, 0, 0.5);
            background: rgba(17, 26, 122, 0.1);
        }

        /* Submit Button */
        button {
            width: 100%;
            background: linear-gradient(135deg, var(--brand-dark), var(--brand-light));
            color: #ffffff;
            border: none;
            border-radius: 8px;
            padding: 16px;
            font-family: 'Tektur', sans-serif;
            font-size: 18px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            position: relative;
            overflow: hidden;
        }

        button:hover {
            box-shadow: 0 0 25px var(--brand-light);
            transform: translateY(-2px);
        }

        /* Success Message */
        #success-message {
            display: none;
            text-align: center;
            font-size: 20px;
            font-weight: 400;
            color: #ffffff;
            padding: 40px 20px;
            border: 1px solid var(--brand-light);
            border-radius: 8px;
            background: rgba(17, 26, 122, 0.2);
            box-shadow: 0 0 20px var(--neon-glow);
        }

        .loader {
            border: 3px solid rgba(255, 255, 255, 0.1);
            border-top: 3px solid var(--brand-light);
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Responsive Design */
        @media (max-width: 600px) {
            h1 {
                font-size: 40px;
            }
            .form-row {
                flex-direction: column;
                gap: 0;
            }
            .glass-panel {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Search Petid Registry</h1>
        
        <div class="glass-panel" id="form-container">
            <form id="registry-form" action="https://formspree.io/f/xqegzggk" method="POST">
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="firstName">First Name</label>
                        <input type="text" id="firstName" name="First Name" required>
                    </div>
                    <div class="form-group">
                        <label for="lastName">Last Name</label>
                        <input type="text" id="lastName" name="Last Name" required>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="Phone" required>
                </div>

                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="Email" required>
                </div>

                <div class="form-group">
                    <label for="microchip">Pet Microchip Number</label>
                    <input type="text" id="microchip" name="Pet Microchip Number" required placeholder="e.g. 981020000000000">
                </div>

                <button type="submit" id="submit-btn">Initiate Search</button>
            </form>
        </div>

        <div id="success-message">
            <div class="loader"></div>
            Querying PetID Registry, will contact you shortly.
        </div>
    </div>

    <script>
        const form = document.getElementById('registry-form');
        const formContainer = document.getElementById('form-container');
        const successMessage = document.getElementById('success-message');

        form.addEventListener('submit', async function(event) {
            event.preventDefault(); // Prevent standard redirect
            
            const data = new FormData(form);
            
            try {
                const response = await fetch(form.action, {
                    method: form.method,
                    body: data,
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                
                if (response.ok) {
                    // Hide form and show custom futuristic message
                    formContainer.style.display = 'none';
                    successMessage.style.display = 'block';
                    form.reset();
                } else {
                    alert('Error connecting to the registry. Please try again.');
                }
            } catch (error) {
                alert('Network error. Please check your connection.');
            }
        });
    </script>

</body>
</html>
